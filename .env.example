# Anthropic
ANTHROPIC_API_KEY=

# Models
CALQEN_ORCHESTRATOR_MODEL=claude-sonnet-4-6
CALQEN_ARCHITECT_MODEL=claude-sonnet-4-6
CALQEN_FAST_MODEL=claude-haiku-4-5-20251001

# Telegram
TELEGRAM_BOT_TOKEN=
AUTHORIZED_TELEGRAM_USER_IDS=    # comma-separated integers
AUTHORIZED_TELEGRAM_CHAT_IDS=    # comma-separated integers

# API auth
CALQEN_BOT_SERVICE_TOKEN=        # bot → API shared secret

# Database
DATABASE_URL=              # Supabase transaction pool (port 6543) — runtime
MIGRATIONS_DATABASE_URL=   # Supabase direct connection (port 5432) — migrations only
SUPABASE_URL=

# GitHub
GITHUB_TOKEN=

# Firecrawl
FIRECRAWL_API_KEY=

# Runner
RUNNER_REGISTRATION_SECRET=
# RUNNER_TOKEN — issued per runner on registration, stored in .runner-token

# Spend controls
CALQEN_DEFAULT_TASK_BUDGET_USD=2.00
CALQEN_MAX_TASK_DURATION_MS=900000
CALQEN_MAX_RESEARCH_SOURCES=5
CALQEN_MAX_AGENT_RETRIES=2

# App
NODE_ENV=development
# CALQEN_API_URL — who's calling determines the value, see docs/deployment.md "Networking":
#   local dev (bot/runner running directly on host)  -> http://localhost:3001
#   VPS Docker services calling the API internally    -> http://api:3001 (set via docker-compose.yml
#                                                          service `environment:`, not this file)
#   Windows Runner in production                       -> https://calqen.duckdns.org
CALQEN_API_URL=http://localhost:3001
PORT=3001

# Runner
RUNNER_DRY_RUN=true
RUNNER_HEARTBEAT_INTERVAL_MS=20000
RUNNER_LEASE_TIMEOUT_MS=60000
RUNNER_POLL_INTERVAL_MS=10000
